{:paths ["src" "resources"]
 ;; Zero third-party runtime deps. Every namespace is portable .cljc for JVM,
 ;; ClojureScript, and SCI-style hosts.
 :deps {io.github.kotoba-lang/office
        {:git/url "https://github.com/kotoba-lang/office.git"
         :git/sha "b5838def811d05f1db1e7d77e5daede8ac953883"}
        io.github.kotoba-lang/ooxml
        {:git/url "https://github.com/kotoba-lang/ooxml.git"
         :git/sha "4b87825e63ecc78bf97f26d98ff87c8bac7a26cd"}
        io.github.kotoba-lang/drawingml
        {:git/url "https://github.com/kotoba-lang/drawingml.git"
         :git/sha "3ce239d800e8ed1d25c17b4e3f2783e0eb9ccf6f"}
        io.github.kotoba-lang/presentationml
        {:git/url "https://github.com/kotoba-lang/presentationml.git"
         :git/sha "1eec72b75ea33c99a25bf0922a643a5c79eb4f8e"}
        io.github.kotoba-lang/office-style
        {:git/url "https://github.com/kotoba-lang/office-style.git"
         :git/sha "40ce484f923475e1bb59919cc03f6664737f0e08"}
        ;; shitsuke: shared UI design system (tokens + hiccup + style +
        ;; portable re-frame seam + components). Pure .cljc, zero runtime deps;
        ;; real reagent/re-frame come via the :cljs alias below.
        io.github.kotoba-lang/shitsuke
        {:git/url "https://github.com/kotoba-lang/shitsuke.git"
         :git/sha "8f6af24d6703d1fc771838e2ee293b58be9f09c4"}}
 :aliases
 {:cli {:main-opts ["-m" "slides.cli"]}
  :local {:override-deps {io.github.kotoba-lang/office
                          {:local/root "../office"}
                          io.github.kotoba-lang/ooxml
                          {:local/root "../ooxml"}
                          io.github.kotoba-lang/drawingml
                          {:local/root "../drawingml"}
                          io.github.kotoba-lang/presentationml
                          {:local/root "../presentationml"}
                          io.github.kotoba-lang/office-style
                          {:local/root "../office-style"}
                          io.github.kotoba-lang/shitsuke
                          {:local/root "../shitsuke"}}}
  :pages {:extra-deps {com.thheller/shadow-css {:mvn/version "0.6.4"
                                  :exclusions [com.thheller/shadow-cljs]}
                      thheller/shadow-cljs {:mvn/version "2.28.21"}}
          :main-opts ["-m" "slides.build"]}
  :cljs {:extra-deps {thheller/shadow-cljs      {:mvn/version "2.28.21"}
                      reagent/reagent           {:mvn/version "1.2.0"}
                      re-frame/re-frame         {:mvn/version "1.4.3"}}
         :main-opts ["-m" "shadow.cljs.devtools.cli" "release" "app"]}
  :test {:extra-paths ["test"]
         :extra-deps {com.thheller/shadow-css {:mvn/version "0.6.4"
                                  :exclusions [com.thheller/shadow-cljs]}
                      thheller/shadow-cljs {:mvn/version "2.28.21"}
                      io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :coverage {:extra-paths ["test"]
             :extra-deps {cloverage/cloverage {:mvn/version "1.2.4"}
                          com.thheller/shadow-css {:mvn/version "0.6.4"
                                  :exclusions [com.thheller/shadow-cljs]}
                      thheller/shadow-cljs {:mvn/version "2.28.21"}
                          io.github.cognitect-labs/test-runner
                          {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
             :main-opts ["-m" "cloverage.coverage"
                         "--ns-regex" "(slides\\.(model|design|routes|render|validate|pptx|office|causal|svgraph|hiccup|site|build|cli|web\\.(events|views|sample|ssr))|kotoba\\.editor)"
                         "--test-ns-regex" "(slides|kotoba)\\..*-test"
                         "--src-ns-path" "src"
                         "--test-ns-path" "test"
                         "--output" "target/coverage"
                         "--no-html"
                         "--text"
                         "--lcov"
                         "--fail-threshold" "85"]}
  :coverage-thresholds {:extra-paths ["test"]
                        :main-opts ["-m" "slides.coverage-gate"]}}}
