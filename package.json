{
  "name": "@kotoba-lang/slides",
  "version": "0.1.0",
  "description": "CLJC EDN deck model and PPTX writer.",
  "license": "MIT",
  "bin": {
    "kotoba-slides": "bin/kotoba-slides.cljs"
  },
  "dependencies": {
    "nbb": "^1.3.204",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "files": [
    "bin",
    "src",
    "deps.edn",
    "README.md"
  ],
  "scripts": {
    "build:pages": "clojure -M:pages && clojure -M:cljs",
    "coverage": "clojure -M:coverage",
    "coverage:thresholds": "clojure -M:coverage-thresholds",
    "test": "clojure -X:test",
    "test:all": "npm test && npm run coverage && npm run coverage:thresholds && npm run test:e2e",
    "test:e2e": "npm run build:pages && nbb test/e2e/slides_import.cljs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "shadow-cljs": "^2.28.21"
  }
}
